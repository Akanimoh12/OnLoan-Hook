# ══════════════════════════════════════════════════════════
# OnLoan — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── RPC Endpoints ──
UNICHAIN_RPC_URL=                          # Unichain mainnet RPC
UNICHAIN_TESTNET_RPC_URL=https://sepolia.unichain.org   # Unichain Sepolia testnet
REACTIVE_RPC_URL=https://kopli-rpc.reactive.network      # Reactive Network Kopli testnet
ETHEREUM_RPC_URL=                          # Ethereum mainnet (for fork tests)

# ── Chain IDs ──
UNICHAIN_CHAIN_ID=1301                     # Unichain Sepolia chain ID

# ── Deployment Keys ──
DEPLOYER_PRIVATE_KEY=                      # Deployer wallet private key (without 0x prefix)
ETHERSCAN_API_KEY=                         # Block explorer verification API key

# ── External Contract Addresses ──
POOL_MANAGER_ADDRESS=0x000000000004444c5dc75cB358380D2e3dE08A90  # Uniswap v4 PoolManager (canonical CREATE2)

# ── Testnet Token Addresses (deploy mocks if needed) ──
WETH_ADDRESS=                              # WETH on Unichain Sepolia
WBTC_ADDRESS=                              # WBTC on Unichain Sepolia

# ── Core Protocol Addresses (filled after DeployOnLoan) ──
ONLOAN_HOOK_ADDRESS=                       # Deployed OnLoanHook
PRICE_ORACLE_ADDRESS=                      # Deployed PriceOracle
LOAN_MANAGER_ADDRESS=                      # Deployed LoanManager
LIQUIDATION_ENGINE_ADDRESS=                # Deployed LiquidationEngine
COLLATERAL_MANAGER_ADDRESS=                # Deployed CollateralManager
LENDING_POOL_ADDRESS=                      # Deployed LendingPool
RSC_LIQUIDATOR_ADDRESS=                    # RSC callback proxy (authorized as liquidator)

# ── RSC Addresses (filled after DeployReactiveMonitor) ──
LIQUIDATION_RSC_ADDRESS=                   # LiquidationRSC on Reactive Network
CROSS_CHAIN_WATCHER_ADDRESS=               # CrossChainCollateralWatcher on Reactive Network

# ── Frontend ──
VITE_UNICHAIN_RPC_URL=https://sepolia.unichain.org   # Public RPC for frontend
VITE_WALLETCONNECT_ID=                     # WalletConnect project ID
VITE_ONLOAN_HOOK_ADDRESS=                 # Hook address for frontend
VITE_CHAIN_ID=1301                         # Chain ID for frontend
